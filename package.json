{
  "name": "ci-cd-node-docker",
  "version": "1.0.0",
  "description": "Minimal Node.js CI/CD demo with GitHub Actions and Docker",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose",
    "lint": "eslint ."
  },
  "keywords": ["ci-cd", "docker", "github-actions", "node", "express"],
  "author": "Suraj Gunagi",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  },
  "jest": {
    "collectCoverage": false,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "clover"],
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 60,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
